#!/bin/bash

# 1. Lock in the directory path BEFORE SetupHelper loads and overwrites variables
PLUGIN_DIR=$(cd "$(dirname "$0")" && pwd)

# Define the package name and log file location for SetupHelper
packageLogFile="/var/log/Janitza/current"

# GitHub automatic updates config
packageGitHubUser="kyros32"
packageGitHubRepo="VenusOS-BMR-Janitza"

# Include the SetupHelper utilities
# This handles the background persistence during firmware updates automatically
source "/data/SetupHelper/HelperResources/IncludeHelpers"

# Define the target directory and files
TARGET_DIR="/opt/victronenergy/dbus-modbus-client"
CLIENT_PY="$TARGET_DIR/dbus-modbus-client.py"
DRIVER_FILE="JanitzaUmg96RM.py"

# The standard SetupHelper install steps
packageAction() {
    case $1 in
        CHECK)
            # This tells the SetupHelper GUI if the package is currently "Active"
            # 1. Check if the import string exists in the main client
            if ! grep -qF "import JanitzaUmg96RM" "$CLIENT_PY"; then
                return 1 # 1 means No, it is not active
            fi
            # 2. Check if the driver file exactly matches our version
            if ! cmp -s "$PLUGIN_DIR/$DRIVER_FILE" "$TARGET_DIR/$DRIVER_FILE"; then
                return 1 # 1 means No, it is missing or outdated
            fi
            return 0 # 0 means Yes, it is fully active and up-to-date
            ;;
            
        INSTALL)
            logMessage "Installing Janitza UMG 96 RM Driver"
            
            # 1. Copy the Python driver to the Victron Modbus client directory
            logMessage "Copying $PLUGIN_DIR/$DRIVER_FILE to $TARGET_DIR"
            cp "$PLUGIN_DIR/$DRIVER_FILE" "$TARGET_DIR/"
            chmod 644 "$TARGET_DIR/$DRIVER_FILE"
            
            # 2. Inject the import into dbus-modbus-client.py if it's missing
            if ! grep -qF "import JanitzaUmg96RM" "$CLIENT_PY"; then
                logMessage "Injecting Janitza import into $CLIENT_PY"
                if grep -qF "import carlo_gavazzi" "$CLIENT_PY"; then
                    sed -i "/^import carlo_gavazzi/a import JanitzaUmg96RM" "$CLIENT_PY"
                else
                    sed -i "/^import /a import JanitzaUmg96RM" "$CLIENT_PY"
                fi
            else
                logMessage "Import already exists in $CLIENT_PY"
            fi
            
            # 3. Remove ALL old compiled bytecode to ensure new code is loaded
            logMessage "Clearing python cache"
            rm -rf "$TARGET_DIR/__pycache__/"
            
            # 4. Explicitly restart the Modbus service
            logMessage "Restarting dbus-modbus-client service"
            svc -t /service/dbus-modbus-client
            
            # 5. Tell SetupHelper to restart the GUI so the package appears in the list automatically
            restartGui=true
            
            return 0
            ;;
            
        UNINSTALL)
            logMessage "Uninstalling Janitza UMG 96 RM Driver"
            
            # 1. Remove the injected line
            sed -i "/import JanitzaUmg96RM/d" "$CLIENT_PY"
            
            # 2. Remove the python driver and ALL cached bytecode
            logMessage "Removing $DRIVER_FILE from $TARGET_DIR"
            rm -f "$TARGET_DIR/$DRIVER_FILE"
            rm -rf "$TARGET_DIR/__pycache__/"
            
            # 3. Explicitly restart the Modbus service
            logMessage "Restarting dbus-modbus-client service"
            svc -t /service/dbus-modbus-client
            
            # 4. Tell SetupHelper to restart the GUI to reflect the uninstallation
            restartGui=true
            
            return 0
            ;;
    esac
}

# Execute the function we just defined using the action requested by SetupHelper
packageAction $scriptAction

# Run the standard script runner provided by SetupHelper
# This connects your packageAction to the Package Manager GUI
endScript
